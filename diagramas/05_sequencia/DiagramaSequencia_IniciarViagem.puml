@startuml
title Diagrama de Sequência — Iniciar Viagem / Desbloqueio via QR Code (UC-03)

hide footbox
skinparam nodesep 55
skinparam ranksep 90

actor "Usuário" as Usuario
boundary "App" as App
control "SistemaMicromobilidade" as Sistema
entity "v:Veículo" as Veiculo
entity "viagem:Viagem" as Viagem

Usuario -> App : lerQRCode()
App -> Sistema : iniciarViagem(usuario, codigoQR)

Sistema -> Sistema : identificarVeículo(codigoQR)
Sistema -> Veiculo : consultarEstado()
Veiculo --> Sistema : estado

alt QR Code válido e veículo disponível ou reservado pelo próprio usuário
  Sistema -> Veiculo : desbloquear()
  Veiculo --> Sistema : estado = EM_USO

  create Viagem
  Sistema -> Viagem : criar(usuario, v)
  Sistema -> Viagem : iniciarRegistroGPS()

  Sistema --> App : viagem iniciada
  App --> Usuario : exibir viagem em andamento

  loop a cada 1 minuto, durante o uso
    Veiculo -> Viagem : registrarPosição(gps)
  end

else veículo indisponível ou reservado por outro usuário
  Sistema --> App : impedir início da viagem
  App --> Usuario : informar indisponibilidade

else QR Code inválido ou ilegível
  Sistema --> App : erro de leitura
  App --> Usuario : solicitar nova leitura
end

@enduml
