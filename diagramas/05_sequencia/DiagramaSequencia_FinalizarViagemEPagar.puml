@startuml
title Diagrama de Sequência — Finalizar Viagem e Pagar (UC-04)

hide footbox
skinparam nodesep 50
skinparam ranksep 85

actor "Usuário" as Usuario
boundary "App" as App
control "SistemaMicromobilidade" as Sistema
entity "viagem:Viagem" as Viagem
entity "v:Veículo" as Veiculo
entity "tarifa:Tarifa" as Tarifa
entity "pacote:Pacote" as Pacote
control "GatewayPagamento" as Gateway
entity "pagamento:Pagamento" as Pagamento

Usuario -> App : solicitarFinalização()
App -> Sistema : finalizarViagem(viagem)

Sistema -> Veiculo : obterPosiçãoAtual()
Veiculo --> Sistema : posição

Sistema -> Sistema : validarÁreaPermitida(posição)

alt veículo fora de área permitida
  Sistema --> App : finalização bloqueada
  App --> Usuario : orientar estacionamento em área permitida

else veículo em área permitida
  Sistema -> Tarifa : obterTarifa(município, tipoVeículo)
  Tarifa --> Sistema : tarifa

  Sistema -> Viagem : calcularValorBase(tarifa)
  Viagem --> Sistema : valorBase

  Sistema -> Pacote : calcularValorComDesconto(taxaDesbloqueio, valorMinutos)
  Pacote --> Sistema : valorComPacote

  opt vínculo acadêmico aprovado
    Sistema -> Sistema : aplicarDescontoAcadêmico()
  end

  opt créditos disponíveis
    Sistema -> Sistema : aplicarCréditos()
  end

  create Pagamento
  Sistema -> Pagamento : criar(valorFinal, formaPagamento)

  Sistema -> Gateway : processarPagamento(valorFinal, formaPagamento)
  Gateway --> Sistema : statusPagamento

  alt pagamento aprovado
    Sistema -> Pagamento : confirmar()
    Sistema -> Viagem : finalizar()

    opt devolução em estação de alta demanda
      Sistema -> Sistema : adicionarCréditosPromocionais()
    end

    Sistema -> Veiculo : atualizarEstado()
    Sistema --> App : viagem finalizada + recibo
    App --> Usuario : exibir recibo

  else pagamento recusado
    Sistema -> Pagamento : recusar()
    Sistema -> Viagem : marcarPagamentoPendente()
    Sistema --> App : cobrança pendente
    App --> Usuario : informar falha no pagamento
  end
end

@enduml
