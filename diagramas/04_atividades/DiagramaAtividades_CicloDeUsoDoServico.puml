@startuml
title Diagrama de Atividades — Ciclo de Uso do Serviço

skinparam nodesep 55
skinparam ranksep 90

start

:Consultar veículos disponíveis no mapa;

if (Existe veículo desejado próximo?) then (sim)
  :Selecionar veículo;

  if (Deseja reservar antes?) then (sim)
    :Reservar veículo\n(prazo de até 5 min);

    if (Desbloqueou dentro do prazo?) then (sim)
      :Ler QR Code e desbloquear o veículo;
    else (não)
      :Reserva expira\nVeículo retorna a DISPONÍVEL;
      stop
    endif

  else (não — desbloqueio imediato)
    :Ler QR Code e desbloquear o veículo;
  endif

  :Iniciar viagem\n(veículo passa a EM USO);

  repeat
    :Utilizar o veículo;
    :Registrar posição GPS\n(a cada 1 min);
  repeat while (Viagem em andamento?) is (sim)

  :Solicitar finalização da viagem;
  :Executar fluxo de finalização,\ntarifação e pagamento;
  :Atualizar histórico e estado do veículo;

  stop

else (não)
  :Informar indisponibilidade na região;
  stop
endif

@enduml
