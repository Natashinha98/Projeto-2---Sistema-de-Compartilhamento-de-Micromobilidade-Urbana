@startuml
title Diagrama de Classes — Sistema de Compartilhamento de Micromobilidade Urbana

skinparam packageStyle rectangle
skinparam nodesep 55
skinparam ranksep 90
skinparam classAttributeIconSize 0
hide empty members

' ===================== Atores / Pessoas =====================
class Usuario {
  - id : int
  - nome : String
  - email : String
  - telefone : String
  - saldoCreditos : double
  + consultarVeiculos() : List<Veiculo>
  + reservarVeiculo(v : Veiculo) : Reserva
  + iniciarViagem(codigoQR : String) : Viagem
  + finalizarViagem(viagem : Viagem) : void
  + reportarDefeito(v : Veiculo, descricao : String) : ReporteDefeito
  + adicionarCreditos(valor : double) : void
}

class UsuarioAcademico {
  + comprovarVinculo(dados : VinculoAcademico) : void
  + possuiDescontoAcademico() : boolean
}

class Administrador {
  - id : int
  - nome : String
  + gerenciarFrota() : void
  + gerenciarTarifa(t : Tarifa) : void
  + gerenciarZona(z : Zona) : void
  + gerarRelatorio(tipo : TipoRelatorio) : Relatorio
}

class EquipeOperacional {
  - id : int
  - nome : String
  + monitorarFrota() : void
  + tratarOrdemServico(os : OrdemServico) : void
}

class VinculoAcademico {
  - instituicao : String
  - matricula : String
  - documento : String
  - tipo : TipoVinculo
  - status : StatusVinculo
}

' ===================== Pacotes (regras de desconto) =====================
abstract class Pacote {
  - nome : String
  + {abstract} calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}
class PacoteBronze {
  + calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}
class PacotePrata {
  + calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}
class PacoteOuro {
  + calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}

' ===================== Veiculo e modelo =====================
class Veiculo {
  - id : int
  - codigoQR : String
  - nivelBateria : int
  - estado : EstadoVeiculo
  + reservar() : void
  + desbloquear() : void
  + bloquear() : void
  + atualizarPosicao(p : Localizacao) : void
  + atualizarBateria(nivel : int) : void
  + precisaRecolhimento() : boolean
}

class ModeloVeiculo {
  - id : int
  - nome : String
  - tipo : TipoVeiculo
  - velocidadeMaximaPadrao : int
}

class Localizacao <<value>> {
  - latitude : double
  - longitude : double
}

class Municipio {
  - id : int
  - nome : String
  - uf : String
}

' ===================== Reserva e viagem =====================
class Reserva {
  - id : int
  - dataHoraInicio : DateTime
  - dataHoraExpiracao : DateTime
  - status : StatusReserva
  + expirou() : boolean
  + cancelar() : void
  + converterEmViagem() : Viagem
}

class Viagem {
  - id : int
  - dataHoraInicio : DateTime
  - dataHoraFim : DateTime
  - valorBase : double
  - valorFinal : double
  - status : StatusViagem
  + calcularDuracao() : int
  + calcularValor(t : Tarifa, p : Pacote) : double
  + registrarPosicao(p : Localizacao) : void
  + finalizar() : void
  + marcarPagamentoPendente() : void
}

class RegistroGPS {
  - dataHora : DateTime
}

' ===================== Tarifação =====================
class Tarifa {
  - id : int
  - tipoVeiculo : TipoVeiculo
  - taxaDesbloqueio : double
  - valorPorMinuto : double
  - ativa : boolean
}

' ===================== Pagamento =====================
class Pagamento {
  - id : int
  - valor : double
  - dataHora : DateTime
  - status : StatusPagamento
  + processar() : void
  + confirmar() : void
  + recusar() : void
}

abstract class FormaPagamento {
  - id : int
  - descricao : String
}
class CartaoCredito {
  - bandeira : String
  - validade : String
}
class CarteiraDigital {
  - provedor : String
}

interface GatewayPagamento {
  + processarPagamento(valor : double, forma : FormaPagamento) : StatusPagamento
}

' ===================== Zonas e regras =====================
class Zona {
  - id : int
  - nome : String
  - tipo : TipoZona
  - velocidadeMaxima : int
  + contem(p : Localizacao) : boolean
}

' ===================== Manutencao =====================
class ReporteDefeito {
  - id : int
  - descricao : String
  - dataHora : DateTime
}

class OrdemServico {
  - id : int
  - dataAbertura : DateTime
  - tipo : TipoOrdemServico
  - motivo : String
  - status : StatusOrdem
  + concluir() : void
}

' ===================== Relatorios =====================
class Relatorio {
  - tipo : TipoRelatorio
  - dataGeracao : DateTime
  - periodo : String
  + gerar() : void
}

' ===================== Enumeracoes =====================
enum EstadoVeiculo {
  DISPONIVEL
  RESERVADO
  EM_USO
  MANUTENCAO
  BATERIA_CRITICA
  RECOLHIDO
}
enum TipoVeiculo {
  BICICLETA
  PATINETE_ELETRICO
}
enum StatusReserva {
  ATIVA
  CONVERTIDA
  EXPIRADA
  CANCELADA
}
enum StatusViagem {
  EM_ANDAMENTO
  PENDENTE_PAGAMENTO
  FINALIZADA
}
enum StatusPagamento {
  PENDENTE
  APROVADO
  RECUSADO
}
enum TipoVinculo {
  ESTUDANTE
  PROFESSOR
}
enum StatusVinculo {
  PENDENTE
  APROVADO
  RECUSADO
}
enum TipoZona {
  ESTACIONAMENTO_PERMITIDO
  AREA_PROIBIDA
  ALTA_DEMANDA
  VELOCIDADE_REDUZIDA
}
enum TipoOrdemServico {
  RECOLHIMENTO
  MANUTENCAO
}
enum StatusOrdem {
  ABERTA
  EM_ANDAMENTO
  CONCLUIDA
}
enum TipoRelatorio {
  UTILIZACAO_POR_REGIAO
  FATURAMENTO_DIARIO
  ALERTAS_OPERACIONAIS
}

' ===================== Heranca =====================
Usuario <|-- UsuarioAcademico
Pacote <|-- PacoteBronze
Pacote <|-- PacotePrata
Pacote <|-- PacoteOuro
FormaPagamento <|-- CartaoCredito
FormaPagamento <|-- CarteiraDigital

' ===================== Associacoes de dominio =====================
Usuario "1" --> "1" Pacote : possui
UsuarioAcademico "1" *-- "0..1" VinculoAcademico
Usuario "1" --> "*" FormaPagamento : cadastra
Usuario "1" --> "*" Reserva : realiza
Usuario "1" --> "*" Viagem : realiza
Usuario "1" --> "*" ReporteDefeito : registra

Veiculo "*" --> "1" ModeloVeiculo : e do
Veiculo "*" --> "1" Municipio : opera em
Veiculo "1" *-- "1" Localizacao : posicao atual

Reserva "*" --> "1" Veiculo : reserva
Viagem "*" --> "1" Veiculo : utiliza
Viagem "1" --> "0..1" Reserva : origina-se de
Viagem "1" *-- "*" RegistroGPS : trajeto
RegistroGPS --> Localizacao
Viagem "1" --> "1" Pagamento : gera
Viagem ..> Tarifa : usa
Viagem ..> Pacote : aplica

Pagamento "*" --> "1" FormaPagamento : usa
Pagamento ..> GatewayPagamento : processa via

Tarifa "*" --> "1" Municipio : vigora em
Zona "*" --> "1" Municipio : pertence a
Zona "1" *-- "*" Localizacao : delimitada por

ReporteDefeito "*" --> "1" Veiculo : refere-se a
OrdemServico "*" --> "1" Veiculo : direcionada a
ReporteDefeito ..> OrdemServico : gera
EquipeOperacional "1" --> "*" OrdemServico : executa

Administrador ..> Tarifa : gerencia
Administrador ..> Zona : gerencia
Administrador ..> Relatorio : gera

@enduml
