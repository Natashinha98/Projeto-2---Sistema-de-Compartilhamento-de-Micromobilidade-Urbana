@startuml
title Diagrama de Classes — Frota e Operação

skinparam nodesep 55
skinparam ranksep 90

skinparam classAttributeIconSize 0
hide empty members

class Veiculo {
  - id : int
  - codigoQR : String
  - nivelBateria : int
  - estado : EstadoVeiculo
  + reservar() : void
  + desbloquear() : void
  + bloquear() : void
  + atualizarPosicao(p : Localizacao) : void
  + atualizarBateria(nivel : int) : void
  + precisaRecolhimento() : boolean
}
class ModeloVeiculo {
  - id : int
  - nome : String
  - tipo : TipoVeiculo
  - velocidadeMaximaPadrao : int
}
class Localizacao <<value>> {
  - latitude : double
  - longitude : double
}
class Municipio {
  - id : int
  - nome : String
  - uf : String
}
class Zona {
  - id : int
  - nome : String
  - tipo : TipoZona
  - velocidadeMaxima : int
  + contem(p : Localizacao) : boolean
}
class ReporteDefeito {
  - id : int
  - descricao : String
  - dataHora : DateTime
}
class OrdemServico {
  - id : int
  - dataAbertura : DateTime
  - tipo : TipoOrdemServico
  - motivo : String
  - status : StatusOrdem
  + concluir() : void
}
class EquipeOperacional {
  - id : int
  - nome : String
  + monitorarFrota() : void
  + tratarOrdemServico(os : OrdemServico) : void
}
class Administrador {
  - id : int
  - nome : String
  + gerenciarFrota() : void
  + gerenciarTarifa(t : Tarifa) : void
  + gerenciarZona(z : Zona) : void
  + gerarRelatorio(tipo : TipoRelatorio) : Relatorio
}
class Relatorio {
  - tipo : TipoRelatorio
  - dataGeracao : DateTime
  - periodo : String
  + gerar() : void
}

enum EstadoVeiculo {
  DISPONIVEL
  RESERVADO
  EM_USO
  MANUTENCAO
  BATERIA_CRITICA
  RECOLHIDO
}
enum TipoVeiculo {
  BICICLETA
  PATINETE_ELETRICO
}
enum TipoZona {
  ESTACIONAMENTO_PERMITIDO
  AREA_PROIBIDA
  ALTA_DEMANDA
  VELOCIDADE_REDUZIDA
}
enum TipoOrdemServico {
  RECOLHIMENTO
  MANUTENCAO
}
enum StatusOrdem {
  ABERTA
  EM_ANDAMENTO
  CONCLUIDA
}
enum TipoRelatorio {
  UTILIZACAO_POR_REGIAO
  FATURAMENTO_DIARIO
  ALERTAS_OPERACIONAIS
}

Veiculo "*" --> "1" ModeloVeiculo : e do
Veiculo "*" --> "1" Municipio : opera em
Veiculo "1" *-- "1" Localizacao : posicao atual
Zona "*" --> "1" Municipio : pertence a
Zona "1" *-- "*" Localizacao : delimitada por
ReporteDefeito "*" --> "1" Veiculo : refere-se a
OrdemServico "*" --> "1" Veiculo : direcionada a
ReporteDefeito ..> OrdemServico : gera
EquipeOperacional "1" --> "*" OrdemServico : executa
Administrador ..> Zona : gerencia
Administrador ..> Relatorio : gera

legend left
  Relacoes com outros domínios (ver Visão Geral):
  Reserva e Viagem --> Veiculo
  Tarifa --> Municipio (vigora em)
  Administrador ..> Tarifa (gerencia)
end legend

@enduml
