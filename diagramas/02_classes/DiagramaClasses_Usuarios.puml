@startuml
title Diagrama de Classes — Usuários e Pacotes

skinparam nodesep 55
skinparam ranksep 90

skinparam classAttributeIconSize 0
hide empty members

class Usuario {
  - id : int
  - nome : String
  - email : String
  - telefone : String
  - saldoCreditos : double
  + consultarVeiculos() : List<Veiculo>
  + reservarVeiculo(v : Veiculo) : Reserva
  + iniciarViagem(codigoQR : String) : Viagem
  + finalizarViagem(viagem : Viagem) : void
  + reportarDefeito(v : Veiculo, descricao : String) : ReporteDefeito
  + adicionarCreditos(valor : double) : void
}

class UsuarioAcademico {
  + comprovarVinculo(dados : VinculoAcademico) : void
  + possuiDescontoAcademico() : boolean
}

class VinculoAcademico {
  - instituicao : String
  - matricula : String
  - documento : String
  - tipo : TipoVinculo
  - status : StatusVinculo
}

abstract class Pacote {
  - nome : String
  + {abstract} calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}
class PacoteBronze {
  + calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}
class PacotePrata {
  + calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}
class PacoteOuro {
  + calcularValorComDesconto(taxaDesbloqueio : double, valorMinutos : double) : double
}

enum TipoVinculo {
  ESTUDANTE
  PROFESSOR
}
enum StatusVinculo {
  PENDENTE
  APROVADO
  RECUSADO
}

Usuario <|-- UsuarioAcademico
UsuarioAcademico "1" *-- "0..1" VinculoAcademico
Usuario "1" --> "1" Pacote : possui
Pacote <|-- PacoteBronze
Pacote <|-- PacotePrata
Pacote <|-- PacoteOuro

legend left
  Relacoes com outros domínios (ver Visão Geral):
  Usuario --> Reserva, Viagem, ReporteDefeito, FormaPagamento
  Viagem ..> Pacote (aplica desconto)
end legend

@enduml
