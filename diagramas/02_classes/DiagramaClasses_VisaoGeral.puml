@startuml

title Diagrama de Classes — Visão Geral (mapa simplificado de domínios)
left to right direction
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam nodesep 70
skinparam ranksep 90
hide empty members

package "Usuários e Pacotes" {
  class Usuario
  abstract class Pacote
}

package "Frota e Operação" {
  class Veiculo
  class Zona
  class OrdemServico
}

package "Viagem e Pagamento" {
  class Reserva
  class Viagem
  class Tarifa
  class Pagamento
}

Usuario "1" --> "1" Pacote : possui
Usuario "1" --> "0..*" Reserva : realiza
Usuario "1" --> "0..*" Viagem : realiza

Reserva "0..*" --> "1" Veiculo : reserva
Viagem "0..*" --> "1" Veiculo : utiliza
Viagem "1" --> "1" Tarifa : usa
Viagem "1" --> "1" Pagamento : gera
OrdemServico "0..*" --> "1" Veiculo : direcionada a
Zona "1" --> "0..*" Veiculo : delimita operação


@enduml
