@startuml
title Diagrama de Casos de Uso — Uso do Serviço

left to right direction
skinparam packageStyle rectangle
skinparam nodesep 55
skinparam ranksep 90

actor "Usuário" as Usuario
actor "Usuário Acadêmico" as UsuarioAcademico
actor "Serviço GPS/Mapa" as GPS
actor "Firmware do Veículo" as Firmware

Usuario <|-- UsuarioAcademico

rectangle "Uso do Serviço" {
  usecase "Consultar veículos\ndisponíveis" as UC_Consultar
  usecase "Reservar veículo" as UC_Reservar
  usecase "Desbloquear veículo\nvia QR Code" as UC_Desbloquear
  usecase "Iniciar viagem" as UC_Iniciar
  usecase "Consultar histórico\nde viagens" as UC_Historico
  usecase "Consultar créditos" as UC_Creditos
  usecase "Reportar defeito" as UC_Reportar
  usecase "Comprovar vínculo\nacadêmico" as UC_Vinculo
}

Usuario --> UC_Consultar
Usuario --> UC_Reservar
Usuario --> UC_Desbloquear
Usuario --> UC_Iniciar
Usuario --> UC_Historico
Usuario --> UC_Creditos
Usuario --> UC_Reportar

UsuarioAcademico --> UC_Vinculo
GPS --> UC_Consultar
Firmware --> UC_Desbloquear

UC_Iniciar .> UC_Desbloquear : <<include>>

note right of UC_Iniciar
  O início da viagem ocorre
  após o desbloqueio do
  veículo via QR Code.
end note
@enduml
