@startuml
title Diagrama de Casos de Uso — Visão Geral

left to right direction
skinparam packageStyle rectangle
skinparam nodesep 55
skinparam ranksep 90

actor "Usuário" as Usuario
actor "Usuário Acadêmico" as UsuarioAcademico
actor "Administrador" as Administrador
actor "Equipe Operacional" as Equipe
actor "Gateway de Pagamento" as Gateway

Usuario <|-- UsuarioAcademico

rectangle "Sistema de Compartilhamento de Micromobilidade Urbana" {

  package "Uso do Serviço" {
    usecase "Consultar veículos\ndisponíveis" as UC_Consultar
    usecase "Reservar veículo" as UC_Reservar
    usecase "Iniciar viagem" as UC_Iniciar
    usecase "Finalizar viagem\ne pagar" as UC_Finalizar
    usecase "Reportar defeito" as UC_Reportar
    usecase "Comprovar vínculo\nacadêmico" as UC_Vinculo
  }

  package "Administração" {
    usecase "Gerenciar frota" as UC_Frota
    usecase "Gerenciar tarifas" as UC_Tarifas
    usecase "Gerenciar zonas\ne limites" as UC_Zonas
    usecase "Gerar relatórios\noperacionais" as UC_Relatorios
  }

  package "Operação e Manutenção" {
    usecase "Monitorar frota\ne manutenção" as UC_Monitorar
    usecase "Tratar ordens\nde serviço" as UC_Ordens
  }
}

Usuario --> UC_Consultar
Usuario --> UC_Reservar
Usuario --> UC_Iniciar
Usuario --> UC_Finalizar
Usuario --> UC_Reportar
UsuarioAcademico --> UC_Vinculo

Gateway --> UC_Finalizar

Administrador --> UC_Frota
Administrador --> UC_Tarifas
Administrador --> UC_Zonas
Administrador --> UC_Relatorios

Equipe --> UC_Monitorar
Equipe --> UC_Ordens
@enduml
